// captain-codex zellij layout — two tabs + floating status pane
// This is a template. The entry point script generates the actual layout
// by substituting CAPTAIN_CMD_PLACEHOLDER with the real orchestrator command.

layout {
    tab name="Codex" focus=true {
        pane
        floating_panes {
            pane {
                command "bash"
                args "-c" "CAPTAIN_CMD_PLACEHOLDER"
                name "Captain"
                width "40%"
                height "30%"
                x "58%"
                y "68%"
            }
        }
    }
    tab name="Claude" {
        pane
    }
}
