// captain-codex zellij layout — three vertical panes: Captain, Codex, Claude
// This is a template. The entry point script generates the actual layout
// by substituting CAPTAIN_CMD_PLACEHOLDER with the real orchestrator command.
//
// Codex and Claude panes are plain shells. The orchestrator types one-shot
// commands into them via write-chars, preserving full TTY (colors, errors).

layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="vertical" {
        pane name="Captain" focus=true {
            command "bash"
            args "-c" "CAPTAIN_CMD_PLACEHOLDER"
        }
        pane name="Codex"
        pane name="Claude"
    }
    pane size=2 borderless=true {
        plugin location="status-bar"
    }
}
