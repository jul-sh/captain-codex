#!/usr/bin/env bash
# Mock codex CLI for testing
# Simulates `codex exec -o <output_file> --full-auto - < prompt.md`
#
# Behavior controlled by env vars:
#   MOCK_CODEX_REVIEW_VERDICT — "APPROVE" or "REJECT" (default: APPROVE)
#   MOCK_CODEX_REJECT_ROUNDS  — reject for this many rounds, then approve (default: 0)
#
# State tracking for multi-round reviews:
#   MOCK_CODEX_STATE_FILE — path to a file tracking review count across invocations

review_verdict="${MOCK_CODEX_REVIEW_VERDICT:-APPROVE}"
reject_rounds="${MOCK_CODEX_REJECT_ROUNDS:-0}"
state_file="${MOCK_CODEX_STATE_FILE:-/tmp/mock-codex-state-$$}"

# Parse flags (mimic codex exec interface)
output_file=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    exec) shift ;;
    -o) output_file="$2"; shift 2 ;;
    --full-auto) shift ;;
    -) shift ;;  # read from stdin
    *) shift ;;
  esac
done

# Read prompt from stdin
input=$(cat)

# Track review count across invocations
review_count=0
if [[ -f "$state_file" ]]; then
  review_count=$(cat "$state_file")
fi

write_output() {
  local text="$1"
  echo "$text"
  if [[ -n "$output_file" ]]; then
    printf '%s\n' "$text" > "$output_file"
  fi
}

# Detect what kind of prompt this is
if echo "$input" | grep -qi "review\|VERDICT\|implementation against"; then
  review_count=$((review_count + 1))
  echo "$review_count" > "$state_file"

  if [[ "$reject_rounds" -gt 0 && "$review_count" -le "$reject_rounds" ]]; then
    write_output "Reviewing implementation...

Issues found:
- Missing error handling in main module
- Test coverage is incomplete

VERDICT: REJECT

Please address the issues above before resubmitting."
  else
    write_output "Reviewing implementation...

Implementation matches the plan. All criteria met.

VERDICT: APPROVE"
  fi
elif echo "$input" | grep -qi "plan\|formalize.*plan\|delegatable"; then
  # Planning request — check if we need to write a plan file
  plan_path=$(echo "$input" | grep -oE '[^ ]*tasks/[^ ]*\.md' | head -1)
  if [[ -n "$plan_path" ]]; then
    mkdir -p "$(dirname "$plan_path")"
    cat > "$plan_path" <<'PLAN'
# Mock Plan

## Objective
Implement the requested feature.

## Steps
1. Create the necessary files
2. Write the code
3. Test it

## Acceptance Criteria
- Feature works as described
- Tests pass
PLAN
    write_output "Plan written to $plan_path"
  else
    write_output "I have analyzed the codebase and drafted a plan.
The implementation should follow a modular approach."
  fi
else
  write_output "Acknowledged: $(echo "$input" | head -c 80)"
fi
