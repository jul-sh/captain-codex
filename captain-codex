#!/usr/bin/env bash
# captain-codex — Zellij-native orchestrator entry point
#
# Usage:
#   captain-codex <task description> [flags]
#
# Flags:
#   --skip-plan <path>   Use an existing plan file, skip planning phase
#   --max-rounds <n>     Cap review iterations (default: from config)
#   --supervised         Pause after planning and each review for human approval
#
# Requires: zellij, codex, claude, jq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Dependency checks ─────────────────────────────────────────────────────────

for cmd in zellij codex claude jq; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "ERROR: '$cmd' is required but not found in PATH." >&2
    exit 1
  fi
done

# ── Parse flags ───────────────────────────────────────────────────────────────

skip_plan=""
max_rounds=""
supervised="false"
task_parts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-plan)
      skip_plan="$2"
      shift 2
      ;;
    --max-rounds)
      max_rounds="$2"
      shift 2
      ;;
    --supervised)
      supervised="true"
      shift
      ;;
    *)
      task_parts+=("$1")
      shift
      ;;
  esac
done

task="${task_parts[*]:-}"
if [[ -z "$task" && -z "$skip_plan" ]]; then
  echo "Usage: captain-codex <task description> [--skip-plan <path>] [--max-rounds <n>] [--supervised]" >&2
  exit 1
fi

# Default task description when skipping plan
if [[ -z "$task" ]]; then
  task="(resuming from existing plan: $skip_plan)"
fi

# ── Export orchestrator env vars ──────────────────────────────────────────────

export SKIP_PLAN="$skip_plan"
export MAX_ROUNDS="$max_rounds"
export SUPERVISED="$supervised"
# Ad-hoc instructions are not parsed from natural language here — pass them
# via environment if needed:
#   ADHOC_PLAN="..." ADHOC_IMPL="..." ADHOC_REVIEW="..." captain-codex "task"

# ── Export task for orchestrator ──────────────────────────────────────────────
# Pass the task via environment variable to avoid shell/KDL escaping issues
# with special characters in the task description.

export CAPTAIN_TASK="$task"

orchestrator_cmd="$SCRIPT_DIR/scripts/orchestrate.sh"

# ── Launch in zellij ──────────────────────────────────────────────────────────

if [[ -n "${ZELLIJ:-}" ]]; then
  # Already inside a zellij session — create Captain tab and run orchestrator
  echo "Inside zellij session. Creating Captain tab..."
  zellij action new-tab -n "Captain" -- bash -c "$orchestrator_cmd"
  echo "Captain tab launched."
  echo "Switch between Captain, Codex, and Claude tabs to watch progress."
else
  # Not inside zellij — generate a layout with the orchestrator command baked in,
  # then start a new session with it.
  layout_template="$SCRIPT_DIR/templates/zellij-layout.kdl"
  generated_layout="/tmp/captain-codex-layout-$$.kdl"

  sed "s|CAPTAIN_CMD_PLACEHOLDER|$orchestrator_cmd|g" "$layout_template" > "$generated_layout"

  echo "Starting zellij session..."
  exec zellij -s "captain-codex-$(date +%s)" -n "$generated_layout"
fi
