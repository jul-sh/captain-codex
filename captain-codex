#!/usr/bin/env bash
# captain-codex — Zellij-native orchestrator entry point
#
# Usage:
#   captain-codex <task description> [flags]
#
# Flags:
#   --skip-plan <path>   Use an existing plan file, skip planning phase
#   --max-rounds <n>     Cap review iterations (default: from config)
#   --supervised         Pause after planning and each review for human approval
#
# Requires: zellij, codex, claude, jq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Dependency checks ─────────────────────────────────────────────────────────

for cmd in zellij codex claude jq; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "ERROR: '$cmd' is required but not found in PATH." >&2
    exit 1
  fi
done

# ── Parse flags ───────────────────────────────────────────────────────────────

skip_plan=""
max_rounds=""
supervised="false"
task_parts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-plan)
      skip_plan="$2"
      shift 2
      ;;
    --max-rounds)
      max_rounds="$2"
      shift 2
      ;;
    --supervised)
      supervised="true"
      shift
      ;;
    *)
      task_parts+=("$1")
      shift
      ;;
  esac
done

task="${task_parts[*]:-}"
if [[ -z "$task" && -z "$skip_plan" ]]; then
  echo "Usage: captain-codex <task description> [--skip-plan <path>] [--max-rounds <n>] [--supervised]" >&2
  exit 1
fi

# Default task description when skipping plan
if [[ -z "$task" ]]; then
  task="(resuming from existing plan: $skip_plan)"
fi

# ── Export orchestrator env vars ──────────────────────────────────────────────

export SKIP_PLAN="$skip_plan"
export MAX_ROUNDS="$max_rounds"
export SUPERVISED="$supervised"
# Ad-hoc instructions are not parsed from natural language here — pass them
# via environment if needed:
#   ADHOC_PLAN="..." ADHOC_IMPL="..." ADHOC_REVIEW="..." captain-codex "task"

# ── Build orchestrator command ────────────────────────────────────────────────

orchestrator_cmd="$SCRIPT_DIR/scripts/orchestrate.sh $(printf '%q' "$task")"

# ── Launch in zellij ──────────────────────────────────────────────────────────

if [[ -n "${ZELLIJ:-}" ]]; then
  # Already inside a zellij session — launch orchestrator as a pinned floating pane
  echo "Inside zellij session. Launching Captain as floating pane..."

  zellij action new-pane --floating --pinned true \
    --name "Captain" \
    --width "40%" --height "30%" \
    --x "58%" --y "68%" \
    -- bash -c "$orchestrator_cmd"

  echo "Captain status pane launched (floating, pinned)."
  echo "Switch between Codex and Claude tabs to watch the agents work."
else
  # Not inside zellij — generate a layout with the orchestrator command baked in,
  # then start a new session with it.
  layout_template="$SCRIPT_DIR/templates/zellij-layout.kdl"
  generated_layout="/tmp/captain-codex-layout-$$.kdl"

  # Escape the command for KDL string embedding (backslashes and double quotes)
  escaped_cmd=$(echo "$orchestrator_cmd" | sed 's/\\/\\\\/g; s/"/\\"/g')

  sed "s|CAPTAIN_CMD_PLACEHOLDER|$escaped_cmd|g" "$layout_template" > "$generated_layout"

  echo "Starting zellij session with Captain, Codex, and Claude tabs..."
  exec zellij -s "captain-codex-$(date +%s)" -l "$generated_layout"
fi
