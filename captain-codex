#!/usr/bin/env bash
# captain-codex — Zellij-native orchestrator entry point
#
# Usage:
#   captain-codex <task description> [flags]
#
# Flags:
#   --skip-plan <path>   Use an existing plan file, skip planning phase
#   --max-rounds <n>     Cap review iterations (default: from config)
#   --supervised         Pause after planning and each review for human approval
#
# Requires: zellij, codex, claude, jq

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ── Dependency checks ─────────────────────────────────────────────────────────

for cmd in zellij codex claude jq; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "ERROR: '$cmd' is required but not found in PATH." >&2
    exit 1
  fi
done

# ── Parse flags ───────────────────────────────────────────────────────────────

skip_plan=""
max_rounds=""
supervised="false"
task_parts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --skip-plan)
      skip_plan="$2"
      shift 2
      ;;
    --max-rounds)
      max_rounds="$2"
      shift 2
      ;;
    --supervised)
      supervised="true"
      shift
      ;;
    *)
      task_parts+=("$1")
      shift
      ;;
  esac
done

task="${task_parts[*]:-}"
if [[ -z "$task" && -z "$skip_plan" ]]; then
  echo "Usage: captain-codex <task description> [--skip-plan <path>] [--max-rounds <n>] [--supervised]" >&2
  exit 1
fi

# Default task description when skipping plan
if [[ -z "$task" ]]; then
  task="(resuming from existing plan: $skip_plan)"
fi

# ── Build zellij launch ───────────────────────────────────────────────────────
# Generate a layout with three vertical panes (Captain, Codex, Claude) and hand
# it to zellij. We pass task/flags via a launcher script so the orchestrator
# does not depend on environment inheritance from the zellij server.

layout_template="$SCRIPT_DIR/templates/zellij-layout.kdl"
generated_layout="/tmp/captain-codex-layout-$$.kdl"
launcher_script="/tmp/captain-codex-launch-$$.sh"

adhoc_plan="${ADHOC_PLAN:-}"
adhoc_impl="${ADHOC_IMPL:-}"
adhoc_review="${ADHOC_REVIEW:-}"

quoted_skip_plan=$(printf '%q' "$skip_plan")
quoted_max_rounds=$(printf '%q' "$max_rounds")
quoted_supervised=$(printf '%q' "$supervised")
quoted_adhoc_plan=$(printf '%q' "$adhoc_plan")
quoted_adhoc_impl=$(printf '%q' "$adhoc_impl")
quoted_adhoc_review=$(printf '%q' "$adhoc_review")
quoted_orchestrator=$(printf '%q' "$SCRIPT_DIR/scripts/orchestrate.sh")
quoted_task=$(printf '%q' "$task")

# Create the tmp dir and log files before zellij starts, so the tail
# commands in the layout panes don't fail.
captain_tmp="/tmp/captain-codex-$$"
mkdir -p "$captain_tmp"
touch "$captain_tmp/codex.log" "$captain_tmp/claude.log"

cat > "$launcher_script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
export CAPTAIN_TMP=$captain_tmp
export SKIP_PLAN=$quoted_skip_plan
export MAX_ROUNDS=$quoted_max_rounds
export SUPERVISED=$quoted_supervised
export ADHOC_PLAN=$quoted_adhoc_plan
export ADHOC_IMPL=$quoted_adhoc_impl
export ADHOC_REVIEW=$quoted_adhoc_review
exec $quoted_orchestrator $quoted_task
EOF
chmod +x "$launcher_script"

escaped_launcher_cmd=$(echo "$launcher_script" | sed 's/\\/\\\\/g; s/"/\\"/g')
sed -e "s|CAPTAIN_CMD_PLACEHOLDER|$escaped_launcher_cmd|g" \
    -e "s|CAPTAIN_TMP_PLACEHOLDER|$captain_tmp|g" \
    "$layout_template" > "$generated_layout"

echo "Launching captain-codex layout..."
exec zellij -l "$generated_layout"
